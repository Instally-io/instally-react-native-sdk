{
  "name": "instally-react-native",
  "version": "1.0.0",
  "description": "Track clicks, installs, and revenue from every link in your React Native app",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://instally.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/Instally-io/instally-react-native-sdk"
  },
  "keywords": [
    "react-native",
    "install-tracking",
    "mobile",
    "app-links",
    "revenue-tracking"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.19.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "@react-native-async-storage/async-storage": "^1.19.0",
    "react": "^18.0.0",
    "react-native": "^0.72.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/src/__mocks__/react-native.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.ts"
    }
  }
}
